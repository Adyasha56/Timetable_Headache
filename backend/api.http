### 81. Delete section
DELETE {{base}}/sections/SECTION_ID
Authorization: Bearer {{token}}


# ================================================================
# AI TOUCHPOINT 1 — FACULTY-SUBJECT ALLOCATION (Pre-Solve)
# Purpose : Gemini AI proposes which faculty should teach which subjects
#           before the solver runs. HOD reviews and tweaks.
# Website : Admin/HOD → Timetable → "AI Suggest Allocation" button
#           Shows a table: Subject | Suggested Faculty | Reason | Confidence
#           HOD can accept as-is or change individual rows
#           Then clicks "Generate Timetable" passing the confirmed allocation
# ================================================================

### 82. Get AI-suggested faculty-subject allocation
# Returns: [{ subject_code, subject_name, faculty_id, faculty_name, reason, confidence }]
GET {{base}}/faculty/suggest-allocation?dept_id=DEPARTMENT_ID&semester_id=SEMESTER_ID
Authorization: Bearer {{token}}

###

### 83. Generate timetable WITH AI allocation (section-aware)
# Pass the suggestions from #82 as faculty_allocation
# solver uses these as hard pre-bindings (subject X must be taught by faculty Y)
POST {{base}}/timetables/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "semester_id": "SEMESTER_ID",
  "dept_id": "DEPARTMENT_ID",
  "section_id": "SECTION_ID",
  "faculty_allocation": [
    { "subject_id": "SUBJECT_ID_1", "faculty_id": "FACULTY_ID_1" },
    { "subject_id": "SUBJECT_ID_2", "faculty_id": "FACULTY_ID_2" }
  ]
}

###

### 84. Generate timetable for a section (no AI allocation)
POST {{base}}/timetables/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "semester_id": "SEMESTER_ID",
  "dept_id": "DEPARTMENT_ID",
  "section_id": "SECTION_ID"
}
